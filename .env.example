# Public Supabase client config
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Server-only Supabase credentials
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_DB_URL="postgres://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# App base URL
APP_URL="http://localhost:3000"

# Slack OAuth + Events secrets
SLACK_CLIENT_ID="1234567890.1234567890"
SLACK_CLIENT_SECRET="YOUR_SLACK_CLIENT_SECRET"
SLACK_SIGNING_SECRET="YOUR_SLACK_SIGNING_SECRET"

# 32-byte key, base64 encoded (for AES-GCM token encryption)
# Example generation:
#   openssl rand -base64 32
TOKEN_ENCRYPTION_KEY="BASE64_32_BYTE_KEY"

# Optional queue/dev toggles
DISABLE_QUEUE="false"
VERCEL_REGION="iad1"
